# LeetCode MVP — Environment Variables
# Copy to .env and adjust for your environment.
# Docker Compose uses its own internal URLs; this file is for host-side runs / acceptance tests.

# PostgreSQL (async driver required — models use postgresql.UUID/ARRAY)
DATABASE_URL=postgresql+asyncpg://leetcode:leetcode@localhost:5432/leetcode

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App
APP_PORT=8010
DEBUG=false

# Acceptance test credentials (must match alembic seed migration 002)
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=admin123
TEST_USER_USERNAME=alice
TEST_USER_PASSWORD=alice123
TEST_USER2_USERNAME=bob
TEST_USER2_PASSWORD=bob123
