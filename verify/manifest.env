# verify/manifest.env — canonical e2e contract
# Sourced by CI (e2e job) and the host e2e loop (set -a; . manifest.env), then each
# phase is eval'd. EVERY value containing spaces/operators MUST be single-quoted, or
# `source` executes it at load time and leaves the var EMPTY → the run silently skips
# that phase (false-green). READY must NOT contain a bare `exit` — it is eval'd in the
# caller's shell and would terminate the whole run.

# Phase 1: UP — bring the stack up in phases so alembic migrations (including
# admin seed from 002_seed_users.py) run BEFORE the app starts. create_all() is
# removed from the app startup — alembic owns the schema end-to-end.
UP='docker compose build && docker compose up -d db redis && until docker compose exec -T db pg_isready -U leetcode >/dev/null 2>&1; do sleep 1; done && docker compose run --rm -T app alembic -c /app/alembic.ini upgrade head && docker compose up -d app'

# Phase 2: READY — wait until the API is healthy (retry, no exit; nonzero on failure)
READY='curl -sf --retry 30 --retry-all-errors --retry-delay 2 http://localhost:${APP_PORT:-8010}/healthz'

# Phase 3: ACCEPTANCE — run the black-box acceptance suite
ACCEPTANCE='API_BASE_URL=http://localhost:${APP_PORT:-8010} pytest verify/acceptance/ -v'

# Phase 4: DOWN — tear the stack down
DOWN='docker compose down -v'

# Phase 5: TEST_DEPS — install host-side test dependencies (run once before ACCEPTANCE)
TEST_DEPS='python -m pip install -e ".[dev]"'

# --- Port map (informational — no collisions) ---
# APP_PORT=8010  → container 8000 (FastAPI)
# db: 5432 internal only (no host publish)
# redis: 6379 internal only (no host publish)
